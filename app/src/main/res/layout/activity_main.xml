<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Título -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lei de Ohm - U = R × I"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/edtTensao"/>

    <!-- Campo U (Tensão) -->
    <EditText
        android:id="@+id/edtTensao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Digite a Tensão (U)"
        android:inputType="numberDecimal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintBottom_toTopOf="@id/edtResistencia"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"/>

    <!-- Campo R (Resistência) -->
    <EditText
        android:id="@+id/edtResistencia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Digite a Resistência (R)"
        android:inputType="numberDecimal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edtTensao"
        app:layout_constraintBottom_toTopOf="@id/edtCorrente"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"/>

    <!-- Campo I (Corrente) -->
    <EditText
        android:id="@+id/edtCorrente"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Digite a Corrente (I)"
        android:inputType="numberDecimal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edtResistencia"
        app:layout_constraintBottom_toTopOf="@id/btnCalcular"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"/>

    <!-- Botão Calcular -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCalcular"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calcular"
        android:textColor="@android:color/white"
        app:backgroundTint="#FF0000"
        app:cornerRadius="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edtCorrente"
        app:layout_constraintBottom_toTopOf="@id/txtResultado"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"/>


    <!-- Texto do resultado -->
    <TextView
        android:id="@+id/txtResultado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resultado: "
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnCalcular"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>